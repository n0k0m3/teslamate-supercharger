# Database (same values as TeslaMate)
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_NAME=teslamate
DATABASE_USER=teslamate
DATABASE_PASS=secret

# Tesla Fleet API — register at developer.tesla.com
TESLA_CLIENT_ID=your-client-id
TESLA_CLIENT_SECRET=your-client-secret
# Fleet API region: na (default), eu, or cn
TESLA_FLEET_REGION=na

# MQTT (same broker as TeslaMate)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Tuning
API_FETCH_DELAY_SECONDS=30
SESSION_MATCH_WINDOW_MINUTES=15
